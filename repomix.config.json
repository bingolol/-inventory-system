{
  "$schema": "https://repomix.com/schemas/latest.json",
  "input": {
    "maxFileSize": 50000
  },
  "output": {
    "filePath": "repomix/repomix-output.md",
    "style": "markdown",
    "parsableStyle": false,
    "compress": false,
    "headerText": "This file contains the entire codebase of the inventory-system project, packed by Repomix for AI analysis."
  },
  "ignore": {
    "useGitignore": true,
    "customPatterns": [
      "node_modules/**",
      "frontend/node_modules/**",
      "backend/venv/**",
      "backend/__pycache__/**",
      "frontend/dist/**",
      "*.db",
      "*.db-journal",
      "*.db.pre_numeric_backup",
      "*.log",
      "backend/pdfs/**",
      "backend/uploads/**",
      "hot_backup/**",
      "logs/**",
      ".code-review-graph/**",
      ".joycode/**",
      "*.zip",
      "backend/inventory.db*",
      "frontend/package-lock.json"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}